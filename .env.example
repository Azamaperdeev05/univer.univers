# Тестілеу үшін environment variables үлгісі
# Бұл файлды .env деп көшіріп, өз деректеріңізді енгізіңіз
# ЕСКЕРТУ: .env файлы .gitignore-да бар, GitHub-қа жүктелмейді

# Университет таңдау (kstu немесе kaznu)
TEST_UNIVER=kstu

# Логин деректері (тек локальді тестілеу үшін!)
TEST_USERNAME=your_username_here
TEST_PASSWORD=your_password_here

# Сервер порты:
# Production-та PORT міндетті және strict қолданылады.
# Локалда порт бос болмаса, PORT-ты ауыстырыңыз немесе PORT бермей
# auto-fallback (7435 -> 7436..7499) режимін қолданыңыз.
PORT=7435
